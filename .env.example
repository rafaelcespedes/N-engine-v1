# ComfyUI host. NEVER expose this to the browser — stock ComfyUI has no auth.
COMFY_URL=

# Provider key (Comfy Deploy / RunPod / fal). Server-side only.
COMFY_API_KEY=

# Rate limiting. The generate route is the entire cost surface of this product.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
